{
  "name": "yondle",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Yondle — a daily geography guessing game. Name a city as close as possible to a target distance from the day's start city.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "data:build": "node scripts/build-cities.mjs",
    "data:enrich": "node scripts/enrich-cities.mjs",
    "data:capitals": "node scripts/enrich-capitals.mjs",
    "data:elevation": "node scripts/build-elevation.mjs",
    "screenshot": "node scripts/screenshot.mjs",
    "preview:puzzles": "vite-node scripts/preview-puzzles.mts"
  },
  "dependencies": {
    "@fontsource/calistoga": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "d3-geo": "^3.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.3.3",
    "d3-contour": "^4.0.2",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "playwright-core": "^1.56.1",
    "prettier": "^3.3.3",
    "topojson-server": "^3.0.1",
    "topojson-simplify": "^3.0.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
